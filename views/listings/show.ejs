<% layout("layout/boilerplate.ejs"); %>

<div class="container mt-4">

  <div class="row justify-content-center">
    <div class="col-md-6">

      <img src="<%= listing.image.url %>" class="show-image">

      <h3><%= listing.title %></h3>

      <p><b>Description:</b> <%= listing.description %></p>
      <p><b>Price:</b> ₹ <%= listing.price.toLocaleString("en-IN") %></p>
      <p><b>Location:</b> <%= listing.location %></p>
      <p><b>Country:</b> <%= listing.country %></p>

      <!-- ================= BOOKING SECTION ================= -->
      <hr>
      <h4 class="mt-3">📅 Book This Stay</h4>

      <% if(currentUser) { %>

        <form action="/book/<%= listing._id %>" method="POST">

          <div class="mb-2">
            <label>Check-In</label>
            <input type="date" name="checkIn" class="form-control" required>
          </div>

          <div class="mb-2">
            <label>Check-Out</label>
            <input type="date" name="checkOut" class="form-control" required>
          </div>

          <button class="btn btn-success mt-2 w-100">
            Book Now
          </button>

        </form>

      <% } else { %>

        <p class="text-danger">⚠ Please login to book</p>
        <a href="/login" class="btn btn-primary w-100">Login</a>

      <% } %>

      <!-- ================= END ================= -->

      <hr>
<!--  
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning mt-2">Edit</a>

      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-danger mt-2">Delete</button>
      </form>-->

      <br>
      <a href="/listings" class="btn btn-secondary mt-3">Back</a>

    </div>
  </div>

</div>